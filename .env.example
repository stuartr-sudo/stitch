# Wavespeed AI (primary AI provider for video/image generation)
WAVESPEED_API_KEY=your_wavespeed_api_key

# FAL.ai (for Lens and some Edit Image models)
FAL_KEY=your_fal_key

# Supabase (database and storage)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Images Search (optional - for reference image search)
SERP_API_KEY=your_serp_api_key
# OR use Google Custom Search Engine
# GOOGLE_CSE_API_KEY=your_google_cse_api_key
# GOOGLE_CSE_CX=your_google_cse_cx

# OpenAI (for GPT-4o-mini storyboard generation)
OPENAI_API_KEY=your_openai_key

# Firecrawl (for blog/URL scraping in webhook)
FIRECRAWL_API_KEY=your_firecrawl_key

# Webhook Security (shared secret for /api/webhooks/content)
WEBHOOK_SECRET=your_random_webhook_secret

# ElevenLabs (optional - for production voiceover, user can also BYOK)
ELEVENLABS_API_KEY=your_elevenlabs_key

# Owner email (for server-level key fallback)
OWNER_EMAIL=your_email@example.com

# Exa API (LinkedIn content fetching — optional, per-user key in linkedin_config overrides)
EXA_API_KEY=your_exa_api_key_here

# Hugging Face (optional - for HF model access)
HUGGINGFACE_API_KEY=your_huggingface_api_key

# Google OAuth (for YouTube publishing)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
YOUTUBE_REDIRECT_URI=https://yourapp.com/api/youtube/callback

# Anthropic (for Claude models in Flow Builder LLM Call node)
ANTHROPIC_API_KEY=your_anthropic_key

# Google AI / Gemini (for Gemini models in Flow Builder LLM Call node)
GOOGLE_AI_API_KEY=your_google_ai_api_key
